# ══════════════════════════════════════════════════════════════════════
# MergeMind — Environment Variables
# Copy this file to .env and fill in your values
# ══════════════════════════════════════════════════════════════════════

# ── Gemini ────────────────────────────────────────────────────────────
# Your Gemini API key (required)
# Get one at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Model to use for reviews (default: gemini-2.0-flash)
# Options: gemini-2.0-flash, gemini-2.5-flash, gemini-2.5-pro
GEMINI_MODEL=gemini-2.0-flash

# ── GitHub ────────────────────────────────────────────────────────────
# Secret for validating webhook payloads (must match GitHub webhook config)
# Generate one: python -c "import secrets; print(secrets.token_hex(32))"
GITHUB_WEBHOOK_SECRET=your-webhook-secret-here

# Personal access token for GitHub API (needs 'repo' scope)
# Create one at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your-github-token-here

# ── Database ──────────────────────────────────────────────────────────
# SQLite database path (default is fine for local development)
DATABASE_URL=sqlite:///./mergemind.db

# ── Server ────────────────────────────────────────────────────────────
# Backend URL (update after deployment)
BACKEND_URL=http://localhost:8000

# CORS origins (comma-separated, include your Chrome extension ID)
CORS_ORIGINS=chrome-extension://*,http://localhost:3000
